# Environment configuration for StudentLife-Phenotyping containers
# Copy this file to .env and customize as needed

# ==============================================================================
# MLflow Configuration
# ==============================================================================
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=studentlife-phenotyping

# Model registry names
TRANSFORMER_MODEL_NAME=behavioral-transformer
AUTOENCODER_MODEL_NAME=behavioral-autoencoder

# ==============================================================================
# API Configuration
# ==============================================================================
LOG_LEVEL=INFO
API_PORT=8000
API_HOST=0.0.0.0
WORKERS=2

# ==============================================================================
# Training Configuration
# ==============================================================================
BATCH_SIZE=64
LEARNING_RATE=0.001
EPOCHS=50

# ==============================================================================
# Resource Limits
# ==============================================================================
# API limits
API_CPU_LIMIT=2
API_MEMORY_LIMIT=2G

# Training limits
TRAINING_CPU_LIMIT=4
TRAINING_MEMORY_LIMIT=4G

# ==============================================================================
# Storage Paths
# ==============================================================================
DATA_DIR=./data
MODELS_DIR=./models
REPORTS_DIR=./reports
MLFLOW_ARTIFACTS_DIR=/mlflow/artifacts
